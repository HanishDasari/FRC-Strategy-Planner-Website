# FRC Strategy Planner - Environment Variables Template
# Copy this file to .env and fill in the values

# Email Verification (Gmail SMTP)
MAIL_USERNAME=frcstrategyplanner@gmail.com
MAIL_PASSWORD=your_app_password_here

# Flask Security
SECRET_KEY=dev

# PostgreSQL Database (Neon.tech or other)
DATABASE_URL=postgresql://user:password@hostname:port/dbname?sslmode=require
